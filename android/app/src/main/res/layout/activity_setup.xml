<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        android:gravity="center_horizontal">

        <!-- Logo / Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="8dp"
            android:text="Sphere Platform"
            android:textColor="@color/white"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="48dp"
            android:text="@string/setup_subtitle"
            android:textColor="#AAFFFFFF"
            android:textSize="14sp" />

        <!-- Status message (shown during connecting / errors) -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:gravity="center"
            android:minLines="2"
            android:textColor="@color/teal_200"
            android:textSize="14sp"
            android:visibility="gone" />

        <!-- Server URL -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilServerUrl"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="@string/setup_server_url_hint"
            app:boxStrokeColor="@color/teal_200"
            app:hintTextColor="@color/teal_200">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri"
                android:textColor="@color/white"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- API Key -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilApiKey"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:hint="@string/setup_api_key_hint"
            app:boxStrokeColor="@color/teal_200"
            app:hintTextColor="@color/teal_200"
            app:passwordToggleEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etApiKey"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textVisiblePassword"
                android:textColor="@color/white"
                android:fontFamily="monospace"
                android:imeOptions="actionNext" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Device ID (optional — auto-generated if blank) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilDeviceId"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="@string/setup_device_id_hint"
            app:boxStrokeColor="@color/teal_200"
            app:hintTextColor="@color/teal_200"
            app:helperText="@string/setup_device_id_helper"
            app:helperTextTextColor="#AAFFFFFF">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDeviceId"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:textColor="@color/white"
                android:fontFamily="monospace"
                android:imeOptions="actionDone" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- Enroll Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEnroll"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/setup_enroll_button"
            android:textSize="16sp"
            app:backgroundTint="@color/teal_700"
            app:cornerRadius="8dp" />

        <!-- Progress -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone" />

    </LinearLayout>

</ScrollView>
