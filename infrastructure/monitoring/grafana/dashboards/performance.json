{
  "title": "Sphere Platform — Performance",
  "uid": "sphere-performance",
  "tags": ["sphere", "performance"],
  "timezone": "browser",
  "refresh": "10s",
  "schemaVersion": 38,
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "API Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(sphere_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sphere_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(sphere_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 2,
      "title": "DB Connection Pool",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sphere_db_pool_size", "legendFormat": "Pool Size"},
        {"expr": "sphere_db_pool_checked_out", "legendFormat": "Checked Out"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 3,
      "title": "DB Query Duration (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, query_name) (rate(sphere_db_query_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{query_name}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 4,
      "title": "Redis Commands/s",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rate(sphere_redis_commands_total[5m])",
          "legendFormat": "{{command}}"
        },
        {
          "expr": "rate(sphere_redis_errors_total[5m])",
          "legendFormat": "errors/s"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 5,
      "title": "Task Execution Duration (p95)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sphere_task_execution_duration_seconds_bucket[5m])))",
          "legendFormat": "Task p95"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 6,
      "title": "Tasks Total (by status)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "rate(sphere_tasks_total[5m])",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    }
  ],
  "templating": {
    "list": [
      {"name": "datasource", "type": "datasource", "query": "prometheus", "hide": 0}
    ]
  }
}
