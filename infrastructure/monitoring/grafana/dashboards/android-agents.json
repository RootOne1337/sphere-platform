{
  "title": "Sphere Platform — Android Agents",
  "uid": "sphere-android-agents",
  "tags": ["sphere", "android", "agents"],
  "timezone": "browser",
  "refresh": "15s",
  "schemaVersion": 38,
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "Всего устройств",
      "type": "stat",
      "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum(sphere_devices_total)", "legendFormat": "Total"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 2,
      "title": "Устройства онлайн / оффлайн",
      "type": "gauge",
      "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {"expr": "sum(sphere_devices_online) / sum(sphere_devices_total) * 100", "legendFormat": "Online %"}
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {"value": null, "color": "red"},
              {"value": 50, "color": "yellow"},
              {"value": 80, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "WS Подключения (Android Agents)",
      "type": "timeseries",
      "gridPos": {"h": 6, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sphere_ws_connections_active{role=\"android\"}",
          "legendFormat": "Android WS"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 4,
      "title": "Device Commands/s (по типам)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum by (command_type) (rate(sphere_device_commands_total[5m]))",
          "legendFormat": "{{command_type}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 5,
      "title": "Command Status (success vs error)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sum by (status) (rate(sphere_device_commands_total[5m]))",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 6,
      "title": "Stream FPS (по device_id)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sphere_stream_fps",
          "legendFormat": "{{device_id}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "steps": [
              {"value": null, "color": "red"},
              {"value": 15, "color": "yellow"},
              {"value": 24, "color": "green"}
            ]
          }
        }
      }
    },
    {
      "id": 7,
      "title": "Stream Bitrate (kbps)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "targets": [
        {
          "expr": "sphere_stream_bitrate_kbps",
          "legendFormat": "{{device_id}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "kbytes"}}
    }
  ],
  "templating": {
    "list": [
      {"name": "datasource", "type": "datasource", "query": "prometheus", "hide": 0}
    ]
  }
}
