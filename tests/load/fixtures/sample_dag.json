{
  "id": "sample-dag-001",
  "name": "load-test-sample",
  "version": 1,
  "nodes": [
    {
      "id": "node-1",
      "type": "SHELL",
      "command": "echo 'Hello from load test'",
      "timeout_sec": 30,
      "retries": 1,
      "next": ["node-2"]
    },
    {
      "id": "node-2",
      "type": "DELAY",
      "delay_ms": 2000,
      "next": ["node-3"]
    },
    {
      "id": "node-3",
      "type": "SHELL",
      "command": "echo 'Step 2 complete'",
      "timeout_sec": 30,
      "retries": 1,
      "next": ["node-4"]
    },
    {
      "id": "node-4",
      "type": "CONDITION",
      "expression": "result.exit_code == 0",
      "on_true": ["node-5"],
      "on_false": ["node-6"]
    },
    {
      "id": "node-5",
      "type": "SHELL",
      "command": "echo 'Success path'",
      "timeout_sec": 15,
      "retries": 0,
      "next": []
    },
    {
      "id": "node-6",
      "type": "SHELL",
      "command": "echo 'Failure path'",
      "timeout_sec": 15,
      "retries": 0,
      "next": []
    }
  ],
  "entry_node": "node-1",
  "metadata": {
    "description": "Тестовый DAG для нагрузочного тестирования",
    "estimated_duration_sec": 10,
    "created_at": "2025-01-01T00:00:00Z"
  }
}
