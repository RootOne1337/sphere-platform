FROM python:3.12-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y \
    libpq-dev \
    gcc \
    && rm -rf /var/lib/apt/lists/*

# Install Python deps from backend/requirements.txt
COPY backend/requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# In dev, source code is mounted via volume (./:/app)
# PYTHONPATH=/app enables: from backend.core import ...

EXPOSE 8000

# Default for production-like runs; docker-compose.override.yml overrides this
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
